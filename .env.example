# Backend Configuration
# Copy this file to .env and fill in your actual values

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=False

# Database
DATABASE_URL=sqlite:///./ai_generator.db

# JWT Secrets (IMPORTANT: Generate a strong secret key)
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# JWT Token Expiry
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:8100

# External API Keys
GOOGLE_API_KEY=your-google-gemini-api-key-here
HUGGING_FACE_TOKEN=your-huggingface-token-here

# AI Models
GEMINI_MODEL=gemini-2.5-flash
STABLE_DIFFUSION_MODEL=stabilityai/stable-diffusion-xl-base-1.0
